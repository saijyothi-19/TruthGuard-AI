{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://truthguard-ai-production-cefd.up.railway.app/api/:path*" },
    { "source": "/((?!assets/|manifest.json|vite.svg|sw.js|favicon.ico).*)" , "destination": "/index.html" }
  ]
}
